# Copy to scripts/.coolify.env and fill in (file is gitignored)
#
# Coolify → Keys & Tokens → API Tokens → Create
# Resource UUID: open Survey app in Coolify → URL or General settings

COOLIFY_URL=https://coolify.example.com
COOLIFY_TOKEN=your-api-token-here
COOLIFY_RESOURCE_UUID=your-resource-uuid-here

# Optional — defaults shown
HEALTH_URL=https://kraftsurvey.org/api/health
GIT_BRANCH=master
GIT_REMOTE=origin

# Set to 1 to push local master before deploy (requires clean commit intent)
# GIT_PUSH=1
