# ==========================================
# Coolify — Kraftstoff Survey (survey.kraftstoff.app)
# ==========================================
# Coolify → Project → Environment → paste these values
#
# Compose file: docker-compose.yml
# Domain (app service): https://survey.kraftstoff.app:3000
#
# Mark NEXT_PUBLIC_APP_URL as "Available at Buildtime" in Coolify
# so share links are baked correctly into the client bundle.

# --- Required (runtime) ---
# Coolify → Database → Postgres → copy INTERNAL URL (not localhost, not 127.0.0.1)
# IMPORTANT: Enable "Available at Runtime" for DATABASE_URL
# Do NOT use the build stub below — that is only for local Docker builds
DATABASE_URL=postgresql://USER:PASS@YOUR-COOLIFY-POSTGRES-HOST:5432/kraftstoff_survey?schema=public
JWT_SECRET=GENERATE_WITH_openssl_rand_-hex_32
NEXT_PUBLIC_APP_URL=https://survey.kraftstoff.app

# --- Buildtime only (optional) ---
# NEXT_PUBLIC_APP_URL → enable "Available at Buildtime"
# DATABASE_URL → leave buildtime OFF (compose uses a build stub automatically)
# JWT_SECRET → runtime required; buildtime optional (compose uses build stub for docker build)

# --- Optional (if Docker build fails with exit 255 / OOM) ---
# COMPOSE_PARALLEL_LIMIT=1
# COMPOSE_BAKE=false

# --- DNS (at your domain provider) ---
# survey.kraftstoff.app  A  <same VPS IP as kraftstoff.app>
