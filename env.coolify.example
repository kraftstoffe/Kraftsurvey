# ==========================================
# Coolify — Kraftstoff Survey (survey.kraftstoff.app)
# ==========================================
#
# Compose file: docker-compose.yml
# Domain (app): https://survey.kraftstoff.app:3000
#
# IMPORTANT: Do NOT set DATABASE_URL in Coolify.
# Postgres runs inside the compose stack; DATABASE_URL is auto-wired.
# If you already have DATABASE_URL in Coolify → DELETE it (especially build stub).

# --- Required (Runtime) ---
POSTGRES_PASSWORD=GENERATE_WITH_openssl_rand_-hex_16
JWT_SECRET=GENERATE_WITH_openssl_rand_-hex_32
NEXT_PUBLIC_APP_URL=https://survey.kraftstoff.app

# --- Buildtime ---
# NEXT_PUBLIC_APP_URL → enable "Available at Buildtime"

# --- Optional (build OOM) ---
# COMPOSE_PARALLEL_LIMIT=1
# COMPOSE_BAKE=false
