generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SurveyStatus {
  DRAFT
  LIVE
  CLOSED
}

enum QuestionType {
  SHORT_TEXT
  LONG_TEXT
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  SCALE_5
  SCALE_10
  YES_NO
  DROPDOWN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  surveys      Survey[]
}

model Survey {
  id          String       @id @default(cuid())
  title       String
  description String?
  slug        String       @unique
  status      SurveyStatus @default(DRAFT)
  ownerId     String
  owner       User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  questions   Question[]
  responses   Response[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([ownerId])
  @@index([slug])
}

model Question {
  id       String       @id @default(cuid())
  surveyId String
  survey   Survey       @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  type     QuestionType
  text     String
  options  String?
  required Boolean      @default(false)
  order    Int
  answers  Answer[]

  @@index([surveyId])
}

model Response {
  id          String   @id @default(cuid())
  surveyId    String
  survey      Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  fingerprint String
  durationMs  Int?
  createdAt   DateTime @default(now())
  answers     Answer[]

  @@unique([surveyId, fingerprint])
  @@index([surveyId])
}

model Answer {
  id         String   @id @default(cuid())
  responseId String
  response   Response @relation(fields: [responseId], references: [id], onDelete: Cascade)
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  value      String

  @@unique([responseId, questionId])
  @@index([responseId])
  @@index([questionId])
}
