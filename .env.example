# Database (PostgreSQL — use docker compose postgres or your own instance)
POSTGRES_USER=survey
POSTGRES_PASSWORD=survey
POSTGRES_DB=kraftstoff_survey
DATABASE_URL="postgresql://survey:survey@localhost:5432/kraftstoff_survey"

# Auth
JWT_SECRET="change-me-in-production-use-a-long-random-string"

# Public URL for share links
NEXT_PUBLIC_APP_URL="https://survey.kraftstoff.app"

# Host port when using docker compose
PORT=3000
